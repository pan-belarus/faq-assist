# PostgreSQL (docker-compose sets DATABASE_URL)
# DATABASE_URL=postgresql+asyncpg://ec_db_user:ec_db_pass@localhost:5436/ec_db

# Google Gemini — one key for embeddings (Chroma) and LLM. Get it at https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Chroma (optional)
# CHROMA_PERSIST_DIRECTORY=./chroma_data
# CHROMA_COLLECTION_NAME=faq_collection

# Neo4j (optional; калі зададзена — у RAG дадаецца кантэкст з вузлоў :FAQ {text})
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4jpassword

# Models (optional)
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# GEMINI_MODEL=gemini-2.5-flash

# Redis (for docker)
# REDIS_PASSWORD=
